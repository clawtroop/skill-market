# === Server ===
PORT=4000
# Comma separated CORS origins or leave empty for *
CORS_ORIGINS=

# Optional: protect /internal/* and other admin paths (if you add any)
INTERNAL_API_TOKEN=change-me-to-strong-random

# === Database (Postgres) ===
DATABASE_URL=postgres://skillmarket:skillmarket@localhost:5432/skillmarket

# === Volcano TOS (火山引擎对象存储) ===
# 火山原生 SDK 用不带 -s3 的域名；华东2(上海)为 https://tos-cn-shanghai.volces.com
# 注意：tos-s3-* 是 S3 兼容域名（给 aws-sdk 用），nanobee-dev.tos-* 是桶虚拟主机域名（SDK 会自动拼桶名），
# 本服务用 @volcengine/tos-sdk，endpoint 填不带桶名、不带 -s3 的那个。
# AK/SK 在控制台「密钥管理」申请：https://console.volcengine.com/iam/keymanage/
TOS_ENDPOINT=https://tos-cn-shanghai.volces.com
TOS_ACCESS_KEY=your-access-key
TOS_SECRET_KEY=your-secret-key
TOS_BUCKET=nanobee-dev
TOS_REGION=cn-shanghai
# 桶内前缀，本桶规划放在 skill-market-mcp/ 下
TOS_PREFIX=skill-market-mcp/

# === Skill Market runtime ===
# Max size for a single resource when (future) load_resource, here mainly for archive validation if needed
SKILL_MARKET_MAX_RESOURCE_BYTES=1048576
# For ingest: where the reference catalog lives (the 501 skill dirs)
# From project root typically:
SKILL_MARKET_INGEST_CATALOG_ROOT=./reference/agent-economic-harness/skill-market/skills

# Public base for constructing archive_url in responses (optional, controller can use request host as fallback)
PUBLIC_BASE_URL=http://localhost:4000
