{
  "name": "skill-market",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Skill Market HTTP service. Provides search, metadata and tar.gz download for skills. Backed by Postgres (metadata) + Volcano TOS (archives).",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node --env-file .env dist/src/main.js",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "migrate": "node --env-file .env dist/scripts/migrate.js || node --env-file .env -r tsx/cjs scripts/migrate.ts",
    "ingest": "node --env-file .env -r tsx/cjs scripts/ingest-skill-market.ts",
    "ingest:dry": "DRY_RUN=1 node --env-file .env -r tsx/cjs scripts/ingest-skill-market.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "@volcengine/tos-sdk": "^2.9.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tar": "^7.4.3",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.20",
    "@types/express": "^4.17.25",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/tar": "^6.1.13",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
